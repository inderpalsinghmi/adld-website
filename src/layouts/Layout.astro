---
interface Props {
  title: string;
  description?: string;
  active?: string;
}

const {
  title,
  description = 'The ADLD Center connects patients, caregivers, researchers, and industry partners to accelerate understanding and treatment of Autosomal Dominant Leukodystrophy.',
  active,
} = Astro.props;

// About Us dropdown is highlighted when on About or Team pages
const aboutActive = active === 'about' || active === 'team';

const mainLinks = [
  { href: 'resources.html',             label: 'Resources',             id: 'resources'             },
  { href: 'research-roadmap.html',      label: 'Research Roadmap',      id: 'research-roadmap'      },
  { href: 'natural-history-study.html', label: 'Natural History Study', id: 'natural-history-study' },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" href="/favicon.svg">
  <script src="https://cdn.tailwindcss.com" is:inline></script>
  <script is:inline>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
            display: ['"Plus Jakarta Sans"', 'Inter', 'system-ui', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    html { font-size: 17px; }
    body { font-family: 'Inter', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
    h1, h2, h3, h4 { font-family: 'Plus Jakarta Sans', 'Inter', system-ui, sans-serif; }
    /* Dropdown */
    .nav-dropdown:hover .nav-dropdown-menu,
    .nav-dropdown:focus-within .nav-dropdown-menu {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    .nav-dropdown-menu {
      opacity: 0;
      visibility: hidden;
      transform: translateY(-6px);
      transition: opacity 0.15s ease, visibility 0.15s ease, transform 0.15s ease;
    }
    .nav-dropdown:hover .nav-chevron { transform: rotate(180deg); }
    .nav-chevron { transition: transform 0.15s ease; }
  </style>
</head>
<body class="bg-white">

<!-- ── Nav ── -->
<nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-xl border-b border-slate-200/70 shadow-sm">
  <div class="max-w-7xl mx-auto px-5 md:px-8 py-3 flex items-center justify-between gap-3">

    <a href="index.html" class="flex-shrink-0">
      <img src="https://adld.center/wp-content/uploads/thegem/logos/logo_21a4025357d7bcc0b6b4d2528b7a9a33_1x.png" alt="ADLD Center" class="h-9 object-contain">
    </a>

    <!-- Desktop links -->
    <div class="hidden lg:flex items-center gap-0.5 flex-1 justify-center">

      <!-- Patients — special badge style -->
      <a
        href="index.html"
        class={`px-3.5 py-1.5 text-[0.82rem] font-bold rounded-lg flex items-center gap-1.5 border transition-colors duration-150 mr-1 ${!active ? 'bg-sky-100 text-sky-700 border-sky-300' : 'bg-sky-50 text-sky-700 border-sky-200 hover:bg-sky-100 hover:border-sky-300'}`}
      >
        <svg class="w-3 h-3 fill-current flex-shrink-0" viewBox="0 0 20 20"><path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"/></svg>
        Patients
      </a>

      <!-- Middle links -->
      {mainLinks.map(link => (
        <a
          href={link.href}
          class={link.id === active
            ? 'px-3.5 py-2 text-[0.82rem] text-[#0a2342] font-semibold bg-slate-100 rounded-lg'
            : 'px-3.5 py-2 text-[0.82rem] text-slate-500 hover:text-[#0a2342] hover:bg-slate-50 rounded-lg font-medium transition-colors duration-150'}
        >
          {link.label}
        </a>
      ))}

      <!-- About Us — dropdown (second to last) -->
      <div class="relative nav-dropdown">
        <button
          class={`px-3.5 py-2 text-[0.82rem] rounded-lg font-medium flex items-center gap-1 transition-colors duration-150 ${aboutActive ? 'text-[#0a2342] font-semibold bg-slate-100' : 'text-slate-500 hover:text-[#0a2342] hover:bg-slate-50'}`}
          aria-haspopup="true"
        >
          About Us
          <svg class="nav-chevron w-3 h-3 flex-shrink-0 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="nav-dropdown-menu absolute top-full left-0 mt-2 w-48 bg-white rounded-xl shadow-xl border border-slate-200 z-50 py-1.5 overflow-hidden">
          <a href="about.html" class={`flex px-4 py-2.5 text-[0.83rem] transition-colors ${active === 'about' ? 'text-[#0a2342] font-semibold bg-slate-50' : 'text-slate-600 hover:text-[#0a2342] hover:bg-slate-50'}`}>About the ADLD Center</a>
          <div class="mx-3 border-t border-slate-100 my-1"></div>
          <a href="team.html"  class={`flex px-4 py-2.5 text-[0.83rem] transition-colors ${active === 'team'  ? 'text-[#0a2342] font-semibold bg-slate-50' : 'text-slate-600 hover:text-[#0a2342] hover:bg-slate-50'}`}>Our Team</a>
        </div>
      </div>

      <!-- Contact — last -->
      <a
        href="contact.html"
        class={active === 'contact'
          ? 'px-3.5 py-2 text-[0.82rem] text-[#0a2342] font-semibold bg-slate-100 rounded-lg'
          : 'px-3.5 py-2 text-[0.82rem] text-slate-500 hover:text-[#0a2342] hover:bg-slate-50 rounded-lg font-medium transition-colors duration-150'}
      >
        Contact
      </a>
    </div>

    <div class="flex items-center gap-3 flex-shrink-0">
      <a
        href="donate.html"
        class={`bg-red-600 text-white px-5 py-2.5 rounded-xl text-[0.82rem] font-bold hover:bg-red-700 active:bg-red-800 transition-colors shadow-sm flex items-center gap-2${active === 'donate' ? ' ring-2 ring-red-300 ring-offset-1' : ''}`}
      >
        <svg class="w-3.5 h-3.5 fill-current flex-shrink-0" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
        Donate
      </a>
      <button id="menu-btn" class="lg:hidden p-2 rounded-lg text-slate-500 hover:bg-slate-100 transition-colors" aria-label="Open menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-slate-100 bg-white/95 backdrop-blur-xl">
    <div class="px-4 py-3 space-y-1">

      <!-- Patients special -->
      <a href="index.html" class={`flex items-center gap-2 px-4 py-2.5 text-sm font-bold rounded-xl border transition-colors ${!active ? 'bg-sky-100 text-sky-700 border-sky-300' : 'bg-sky-50 text-sky-700 border-sky-200'}`}>
        <svg class="w-4 h-4 fill-current flex-shrink-0" viewBox="0 0 20 20"><path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"/></svg>
        Patients &amp; Caregivers
      </a>

      <!-- Middle links -->
      {mainLinks.map(link => (
        <a
          href={link.href}
          class={link.id === active
            ? 'flex px-4 py-2.5 text-sm font-semibold text-[#0a2342] bg-slate-100 rounded-xl'
            : 'flex px-4 py-2.5 text-sm font-medium text-slate-700 hover:text-[#0a2342] hover:bg-slate-50 rounded-xl transition-colors'}
        >
          {link.label}
        </a>
      ))}

      <!-- About accordion (second to last) -->
      <div>
        <button id="mobile-about-btn" class={`flex justify-between items-center w-full px-4 py-2.5 text-sm rounded-xl transition-colors ${aboutActive ? 'font-semibold text-[#0a2342] bg-slate-100' : 'font-medium text-slate-700 hover:text-[#0a2342] hover:bg-slate-50'}`}>
          About Us
          <svg id="mobile-about-chevron" class="w-4 h-4 text-slate-400 transition-transform duration-150" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="mobile-about-sub" class={`mt-1 ml-4 pl-3 border-l-2 border-slate-100 space-y-0.5 ${aboutActive ? '' : 'hidden'}`}>
          <a href="about.html" class={`flex px-3 py-2 text-sm rounded-lg transition-colors ${active === 'about' ? 'text-[#0a2342] font-semibold' : 'text-slate-600 hover:text-[#0a2342] hover:bg-slate-50'}`}>About the ADLD Center</a>
          <a href="team.html"  class={`flex px-3 py-2 text-sm rounded-lg transition-colors ${active === 'team'  ? 'text-[#0a2342] font-semibold' : 'text-slate-600 hover:text-[#0a2342] hover:bg-slate-50'}`}>Our Team</a>
        </div>
      </div>

      <!-- Contact (last) -->
      <a
        href="contact.html"
        class={active === 'contact'
          ? 'flex px-4 py-2.5 text-sm font-semibold text-[#0a2342] bg-slate-100 rounded-xl'
          : 'flex px-4 py-2.5 text-sm font-medium text-slate-700 hover:text-[#0a2342] hover:bg-slate-50 rounded-xl transition-colors'}
      >
        Contact
      </a>

      <div class="pt-2 pb-1">
        <a href="donate.html" class="flex items-center justify-center gap-2 bg-red-600 text-white px-5 py-3 rounded-xl text-sm font-bold hover:bg-red-700 transition-colors">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
          Donate to ADLD Research
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- ── Page content ── -->
<slot />

<!-- ── Footer ── -->
<footer class="bg-[#060f1e] text-white">
  <div class="max-w-6xl mx-auto px-6 md:px-10 pt-14 pb-10">

    <div class="flex flex-col md:flex-row justify-between gap-10 pb-10 border-b border-white/10">
      <div class="max-w-xs">
        <img src="https://adld.center/wp-content/uploads/thegem/logos/logo_21a4025357d7bcc0b6b4d2528b7a9a33_1x.png" alt="ADLD Center" class="h-8 brightness-0 invert mb-4 object-contain">
        <p class="text-slate-400 text-sm leading-relaxed">Connecting patients, researchers, and industry in the fight against Autosomal Dominant Leukodystrophy.</p>
        <a href="donate.html" class="inline-flex items-center gap-2 mt-6 bg-red-600 text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-red-700 transition-colors">
          <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
          Donate Now
        </a>
      </div>
      <div class="grid grid-cols-2 gap-x-16 gap-y-2 text-sm">
        <div class="space-y-2.5">
          <p class="text-slate-500 text-[0.68rem] font-bold uppercase tracking-widest mb-3">Organization</p>
          <a href="index.html"  class="block text-slate-400 hover:text-white transition-colors">Patients</a>
          <a href="about.html"  class="block text-slate-400 hover:text-white transition-colors">About Us</a>
          <a href="team.html"   class="block text-slate-400 hover:text-white transition-colors">Our Team</a>
          <a href="contact.html" class="block text-slate-400 hover:text-white transition-colors">Contact Us</a>
          <a href="donate.html"  class="block text-red-400 hover:text-white transition-colors font-medium">Donate</a>
        </div>
        <div class="space-y-2.5">
          <p class="text-slate-500 text-[0.68rem] font-bold uppercase tracking-widest mb-3">Research</p>
          <a href="research-roadmap.html"      class="block text-slate-400 hover:text-white transition-colors">Research Roadmap</a>
          <a href="natural-history-study.html" class="block text-slate-400 hover:text-white transition-colors">Natural History Study</a>
          <a href="resources.html"             class="block text-slate-400 hover:text-white transition-colors">Resources</a>
        </div>
      </div>
    </div>

    <div class="pt-6 flex flex-wrap items-center justify-between gap-3 text-xs text-slate-600">
      <span>© 2025 ADLD Center. All rights reserved.</span>
      <span>info@adld.center &nbsp;·&nbsp; 507-293-2427</span>
    </div>
  </div>
</footer>

<script is:inline>
  // Mobile hamburger
  document.getElementById('menu-btn').addEventListener('click', function () {
    document.getElementById('mobile-menu').classList.toggle('hidden');
  });
  // Mobile About accordion
  document.getElementById('mobile-about-btn').addEventListener('click', function () {
    var sub = document.getElementById('mobile-about-sub');
    var chevron = document.getElementById('mobile-about-chevron');
    sub.classList.toggle('hidden');
    chevron.style.transform = sub.classList.contains('hidden') ? '' : 'rotate(180deg)';
  });
</script>

</body>
</html>
