---
import Layout from '../layouts/Layout.astro';
import { fetchPageSections } from '../lib/notion.js';

const s = await fetchPageSections('research-roadmap');
---
<Layout
  title="Research Roadmap — ADLD Center"
  description="Our strategic priorities through 2027 — parallel streams of clinical trials, novel drug development, and disease tracking."
  active="research-roadmap"
>

  <!-- ── Banner ── -->
  <section class="relative h-64 md:h-80 overflow-hidden bg-[#060f1e]">
    <img src="/research-roadmap.png" alt="ADLD Research Roadmap" class="absolute inset-0 w-full h-full object-cover object-center opacity-50">
    <div class="absolute inset-0 bg-gradient-to-t from-[#060f1e] via-[#060f1e]/30 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#060f1e]/80 via-transparent to-transparent"></div>
    <div class="absolute inset-0 flex flex-col justify-end px-8 md:px-14 pb-10">
      <p class="text-sky-400 text-[0.68rem] font-bold uppercase tracking-widest mb-2">Updated December 2025</p>
      <h1 class="text-3xl md:text-4xl font-extrabold text-white tracking-tight">Research Roadmap</h1>
      <p class="text-sky-300 text-sm mt-2 max-w-lg">Our agile strategic priorities through 2027 — clinical trials, novel drug development, and disease tracking running in parallel.</p>
    </div>
  </section>

  <!-- ── Intro + Roadmap Image ── -->
  <div class="bg-white border-b border-slate-100 py-12 px-6">
    <div class="max-w-5xl mx-auto">
      <p class="text-slate-600 leading-relaxed max-w-3xl mb-10">At the ADLD Center, we are committed to accelerating progress toward a cure for Autosomal Dominant Leukodystrophy. Our agile roadmap outlines our strategic priorities through 2027, focusing on parallel streams of clinical trials, novel drug development, and comprehensive disease tracking. Every initiative is designed to build on the others — creating momentum that compounds.</p>

      <!-- Roadmap Image -->
      <div class="rounded-2xl overflow-hidden border border-slate-200 shadow-lg">
        <img src="/research-roadmap-full.png" alt="ADLD Agile Research Roadmap 2025–2027" class="w-full h-auto block">
        <div class="bg-slate-50 border-t border-slate-200 px-5 py-3 flex items-center justify-between">
          <p class="text-slate-500 text-xs">ADLD Center Agile Research Roadmap — Updated December 2025</p>
          <a href="/research-roadmap-full.png" target="_blank" class="text-sky-600 hover:text-sky-700 text-xs font-semibold flex items-center gap-1">
            View full size
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Tracks ── -->
  <div class="bg-slate-50 py-12 px-6">
    <div class="max-w-4xl mx-auto space-y-6">

      <!-- Track 1 — ASO Clinical Trial -->
      <Fragment set:html={s['roadmap-t1'] ?? `
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="px-7 pt-7 pb-5 border-b border-slate-100">
            <div class="flex items-center justify-between flex-wrap gap-3">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-[#0a2342] text-white flex items-center justify-center text-xs font-extrabold flex-shrink-0">T1</div>
                <h2 class="text-xl font-extrabold text-[#0a2342]">ASO Clinical Trial Program</h2>
              </div>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-emerald-50 border border-emerald-200 text-emerald-700 text-xs font-bold rounded-full">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>Active — First-in-Human Trial
              </span>
            </div>
          </div>
          <div class="px-7 py-6 space-y-4">
            <p class="text-slate-600 leading-relaxed">Antisense oligonucleotides (ASOs) are synthetic molecules designed to silence the overexpressed <em>LMNB1</em> gene — the root cause of ADLD. The ADLD Center's first-in-human <em>n=1</em> trial marks a historic milestone: the first therapeutic intervention ever attempted for this disease.</p>
            <div class="grid sm:grid-cols-3 gap-3 pt-1">
              <div class="p-4 rounded-xl bg-emerald-50 border border-emerald-100">
                <p class="text-[0.7rem] font-bold uppercase tracking-wider text-emerald-600 mb-1">Completed</p>
                <p class="text-sm font-semibold text-[#0a2342]">Preclinical Validation</p>
                <p class="text-xs text-slate-500 mt-0.5">ASO efficacy confirmed in mouse models</p>
              </div>
              <div class="p-4 rounded-xl bg-emerald-50 border border-emerald-100">
                <p class="text-[0.7rem] font-bold uppercase tracking-wider text-emerald-600 mb-1">Underway</p>
                <p class="text-sm font-semibold text-[#0a2342]">n=1 Compassionate Use Trial</p>
                <p class="text-xs text-slate-500 mt-0.5">First-in-human intrathecal ASO treatment</p>
              </div>
              <div class="p-4 rounded-xl bg-sky-50 border border-sky-100">
                <p class="text-[0.7rem] font-bold uppercase tracking-wider text-sky-600 mb-1">Next</p>
                <p class="text-sm font-semibold text-[#0a2342]">IND Filing & Cohort Expansion</p>
                <p class="text-xs text-slate-500 mt-0.5">Scale to multi-patient Phase I/II trial</p>
              </div>
            </div>
          </div>
        </div>
      `} />

      <!-- Track 2 — Drug Repurposing -->
      <Fragment set:html={s['roadmap-t2'] ?? `
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="px-7 pt-7 pb-5 border-b border-slate-100">
            <div class="flex items-center justify-between flex-wrap gap-3">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-[#0a2342] text-white flex items-center justify-center text-xs font-extrabold flex-shrink-0">T2</div>
                <h2 class="text-xl font-extrabold text-[#0a2342]">Drug Repurposing</h2>
              </div>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-sky-50 border border-sky-200 text-sky-700 text-xs font-bold rounded-full">
                <span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>In Progress
              </span>
            </div>
          </div>
          <div class="px-7 py-6 space-y-4">
            <p class="text-slate-600 leading-relaxed">While ASO development advances, the ADLD Center is simultaneously screening FDA-approved compounds for myelin-protective and neuroprotective effects in ADLD models. Drug repurposing offers the fastest possible path to a treatment patients can access today.</p>
            <div class="grid sm:grid-cols-3 gap-3 pt-1">
              <div class="p-4 rounded-xl bg-emerald-50 border border-emerald-100">
                <p class="text-[0.7rem] font-bold uppercase tracking-wider text-emerald-600 mb-1">Completed</p>
                <p class="text-sm font-semibold text-[#0a2342]">Candidate Identification</p>
                <p class="text-xs text-slate-500 mt-0.5">Shortlist of FDA-approved compounds</p>
              </div>
              <div class="p-4 rounded-xl bg-sky-50 border border-sky-100">
                <p class="text-[0.7rem] font-bold uppercase tracking-wider text-sky-600 mb-1">Underway</p>
                <p class="text-sm font-semibold text-[#0a2342]">Preclinical Screening</p>
                <p class="text-xs text-slate-500 mt-0.5">Testing in <em>LMNB1</em> overexpression models</p>
              </div>
              <div class="p-4 rounded-xl bg-slate-50 border border-slate-100">
                <p class="text-[0.7rem] font-bold uppercase tracking-wider text-slate-500 mb-1">Planned</p>
                <p class="text-sm font-semibold text-[#0a2342]">Clinical Translation</p>
                <p class="text-xs text-slate-500 mt-0.5">Compassionate use or off-label pathway</p>
              </div>
            </div>
          </div>
        </div>
      `} />

      <!-- Track 3 — Natural History Study -->
      <Fragment set:html={s['roadmap-t3'] ?? `
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="px-7 pt-7 pb-5 border-b border-slate-100">
            <div class="flex items-center justify-between flex-wrap gap-3">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-[#0a2342] text-white flex items-center justify-center text-xs font-extrabold flex-shrink-0">T3</div>
                <h2 class="text-xl font-extrabold text-[#0a2342]">Natural History Study</h2>
              </div>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-emerald-50 border border-emerald-200 text-emerald-700 text-xs font-bold rounded-full">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>Now Enrolling
              </span>
            </div>
          </div>
          <div class="px-7 py-6 space-y-4">
            <p class="text-slate-600 leading-relaxed">A longitudinal study of ADLD patients worldwide — tracking disease progression, symptoms, and imaging over time. This dataset will serve as a <strong class="text-[#0a2342]">synthetic control arm</strong> for future clinical trials, dramatically reducing the number of patients needed in placebo groups and accelerating regulatory approval.</p>
            <div class="grid sm:grid-cols-3 gap-3 pt-1">
              <div class="p-4 rounded-xl bg-emerald-50 border border-emerald-100">
                <p class="text-[0.7rem] font-bold uppercase tracking-wider text-emerald-600 mb-1">Live</p>
                <p class="text-sm font-semibold text-[#0a2342]">Global Patient Registry</p>
                <p class="text-xs text-slate-500 mt-0.5">Enrolling patients across multiple countries</p>
              </div>
              <div class="p-4 rounded-xl bg-emerald-50 border border-emerald-100">
                <p class="text-[0.7rem] font-bold uppercase tracking-wider text-emerald-600 mb-1">Underway</p>
                <p class="text-sm font-semibold text-[#0a2342]">Longitudinal Data Collection</p>
                <p class="text-xs text-slate-500 mt-0.5">MRI, functional assessments, biosamples</p>
              </div>
              <div class="p-4 rounded-xl bg-sky-50 border border-sky-100">
                <p class="text-[0.7rem] font-bold uppercase tracking-wider text-sky-600 mb-1">Goal</p>
                <p class="text-sm font-semibold text-[#0a2342]">Synthetic Control Arm</p>
                <p class="text-xs text-slate-500 mt-0.5">FDA-accepted dataset for trial design</p>
              </div>
            </div>
            <a href="natural-history-study.html" class="inline-flex items-center gap-2 mt-2 text-sm font-semibold text-sky-600 hover:text-sky-700">
              Learn more & enroll →
            </a>
          </div>
        </div>
      `} />

      <!-- Track 4 — Biomarker Development -->
      <Fragment set:html={s['roadmap-t4'] ?? `
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="px-7 pt-7 pb-5 border-b border-slate-100">
            <div class="flex items-center justify-between flex-wrap gap-3">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-[#0a2342] text-white flex items-center justify-center text-xs font-extrabold flex-shrink-0">T4</div>
                <h2 class="text-xl font-extrabold text-[#0a2342]">Biomarker Development</h2>
              </div>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-sky-50 border border-sky-200 text-sky-700 text-xs font-bold rounded-full">
                <span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>In Progress
              </span>
            </div>
          </div>
          <div class="px-7 py-6 space-y-4">
            <p class="text-slate-600 leading-relaxed">Without reliable biomarkers, it's impossible to measure whether a treatment is working. The ADLD Center is working to identify blood and CSF biomarkers that reflect disease activity in real time — enabling objective endpoints for clinical trials and faster regulatory decisions.</p>
            <div class="grid sm:grid-cols-3 gap-3 pt-1">
              <div class="p-4 rounded-xl bg-sky-50 border border-sky-100">
                <p class="text-[0.7rem] font-bold uppercase tracking-wider text-sky-600 mb-1">Underway</p>
                <p class="text-sm font-semibold text-[#0a2342]">Candidate Biomarker Panel</p>
                <p class="text-xs text-slate-500 mt-0.5">NfL, GFAP, and myelin-related proteins</p>
              </div>
              <div class="p-4 rounded-xl bg-sky-50 border border-sky-100">
                <p class="text-[0.7rem] font-bold uppercase tracking-wider text-sky-600 mb-1">Underway</p>
                <p class="text-sm font-semibold text-[#0a2342]">NHS Integration</p>
                <p class="text-xs text-slate-500 mt-0.5">Biosamples collected via Natural History Study</p>
              </div>
              <div class="p-4 rounded-xl bg-slate-50 border border-slate-100">
                <p class="text-[0.7rem] font-bold uppercase tracking-wider text-slate-500 mb-1">Planned</p>
                <p class="text-sm font-semibold text-[#0a2342]">Validated Trial Endpoints</p>
                <p class="text-xs text-slate-500 mt-0.5">FDA-qualified biomarker for ADLD trials</p>
              </div>
            </div>
          </div>
        </div>
      `} />

      <!-- Donate CTA -->
      <div class="bg-gradient-to-br from-red-700 to-red-600 text-white rounded-2xl p-7 shadow-md flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <p class="font-bold text-base mb-1">Fund the Research Roadmap</p>
          <p class="text-red-100 text-sm leading-relaxed">Every donation directly accelerates our parallel tracks toward a cure. No overhead — 100% to science.</p>
        </div>
        <a href="donate.html" class="flex-shrink-0 bg-white text-red-700 px-7 py-3 rounded-xl font-bold text-sm hover:bg-red-50 transition-colors text-center">Donate Now</a>
      </div>

    </div>
  </div>

</Layout>
