---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Donate — ADLD Center"
  description="Support ADLD research with a donation. Every dollar advances our path to clinical trials and a cure for Autosomal Dominant Leukodystrophy."
  active="donate"
>

  <!-- ── Hero ── -->
  <section class="bg-gradient-to-br from-[#7f1d1d] via-red-700 to-red-600 text-white py-20 px-8 md:px-14 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 70% 50%, #fca5a5 0%, transparent 50%);"></div>
    <div class="relative max-w-2xl">
      <div class="inline-flex items-center gap-2 bg-white/15 border border-white/20 text-red-100 text-[0.68rem] font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-6">
        <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
        Tax-Deductible Donation
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4 leading-[1.1]">Every Dollar Moves Us<br>Closer to a Cure</h1>
      <p class="text-red-100 text-base leading-relaxed max-w-lg">Your donation directly funds clinical trials, research grants, and the Natural History Study for Autosomal Dominant Leukodystrophy — a fatal disease with zero approved treatments.</p>
    </div>
  </section>

  <!-- ── Content ── -->
  <div class="bg-slate-50 py-12 px-6">
    <div class="max-w-3xl mx-auto space-y-7">

      <!-- Donation methods -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="bg-[#0a2342] text-white px-7 py-5">
          <h2 class="text-lg font-bold">Choose Your Donation Method</h2>
          <p class="text-sky-300 text-sm mt-1">All donations are tax-deductible to the extent permitted by law.</p>
        </div>

        <!-- Credit Card / Givebutter -->
        <div class="p-7 border-b border-slate-100">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-slate-50 rounded-xl flex items-center justify-center text-2xl flex-shrink-0 border border-slate-100">💳</div>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-1 flex-wrap">
                <h3 class="font-bold text-[#0a2342] text-base">Credit or Debit Card</h3>
                <span class="bg-green-100 text-green-700 text-[0.68rem] font-bold px-2.5 py-0.5 rounded-full uppercase tracking-wide">Recommended under $500</span>
              </div>
              <p class="text-slate-500 text-[0.88rem] leading-relaxed mb-4">Quick and easy — donate in seconds using any major credit or debit card. Powered by Givebutter, a trusted nonprofit fundraising platform.</p>
              <a href="https://givebutter.com/adldcenter" target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 bg-red-600 text-white px-7 py-3 rounded-xl font-bold text-sm hover:bg-red-700 transition-colors shadow-sm">
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
                Donate with Card via Givebutter
              </a>
            </div>
          </div>
        </div>

        <!-- E-check / ACH -->
        <div class="p-7">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-slate-50 rounded-xl flex items-center justify-center text-2xl flex-shrink-0 border border-slate-100">🏦</div>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-1 flex-wrap">
                <h3 class="font-bold text-[#0a2342] text-base">E-check / Bank Transfer (ACH)</h3>
                <span class="bg-sky-100 text-sky-700 text-[0.68rem] font-bold px-2.5 py-0.5 rounded-full uppercase tracking-wide">Best for $500+</span>
              </div>
              <p class="text-slate-500 text-[0.88rem] leading-relaxed mb-4">Transfer funds directly from your bank account. No transaction fees means more of your gift goes directly to research. Powered by Stripe.</p>
              <a href="https://donate.stripe.com/adldcenter" target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 bg-[#0a2342] text-white px-7 py-3 rounded-xl font-bold text-sm hover:bg-[#0d2e5a] transition-colors shadow-sm">
                <span class="text-base">🏦</span>
                Donate via Bank Transfer (ACH)
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- What your gift does -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-7">
        <h2 class="text-lg font-bold text-[#0a2342] mb-5 pb-3 border-b border-slate-100">What Your Gift Funds</h2>
        <div class="space-y-4">
          <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-50 border border-slate-100">
            <span class="text-xl flex-shrink-0 mt-0.5">🧬</span>
            <div>
              <p class="font-semibold text-[#0a2342] text-[0.9rem]">Clinical Trial Support</p>
              <p class="text-slate-500 text-[0.85rem] leading-relaxed mt-0.5">Directly contributes to the first-in-human ADLD n=1 clinical trial and the expansion to multi-patient trials in 2026.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-50 border border-slate-100">
            <span class="text-xl flex-shrink-0 mt-0.5">🔬</span>
            <div>
              <p class="font-semibold text-[#0a2342] text-[0.9rem]">Research Grants</p>
              <p class="text-slate-500 text-[0.85rem] leading-relaxed mt-0.5">Funds grants at Mayo Clinic, Henry Ford Health, and the Orphan Disease Center at UPenn — up to $50,000 per grant per year.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-50 border border-slate-100">
            <span class="text-xl flex-shrink-0 mt-0.5">🌍</span>
            <div>
              <p class="font-semibold text-[#0a2342] text-[0.9rem]">Natural History Study</p>
              <p class="text-slate-500 text-[0.85rem] leading-relaxed mt-0.5">Sustains our global, remote Natural History Study — the data backbone that will power synthetic control arms in future FDA trials.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-50 border border-slate-100">
            <span class="text-xl flex-shrink-0 mt-0.5">👥</span>
            <div>
              <p class="font-semibold text-[#0a2342] text-[0.9rem]">Patient &amp; Family Support</p>
              <p class="text-slate-500 text-[0.85rem] leading-relaxed mt-0.5">Supports patient education, community meetups, and resources that help families navigate their ADLD journey.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Other ways to give -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-7">
        <h2 class="text-lg font-bold text-[#0a2342] mb-5 pb-3 border-b border-slate-100">Other Ways to Give</h2>
        <div class="space-y-4 text-[0.92rem] text-slate-600 leading-[1.7]">
          <p><strong class="text-[#0a2342]">Checks:</strong> Make payable to "ADLD Center" and mail to our address. Contact us for mailing details.</p>
          <p><strong class="text-[#0a2342]">Stock Donations:</strong> Contact us directly to arrange a transfer of appreciated securities — this is often the most tax-efficient way to give.</p>
          <p><strong class="text-[#0a2342]">Planned Giving &amp; Bequests:</strong> Leave a lasting legacy for ADLD research. Contact us to discuss estate planning options.</p>
          <p><strong class="text-[#0a2342]">Corporate Matching:</strong> Many employers match charitable contributions. Check with your HR department and have them contact us at <a href="mailto:info@adld.center" class="text-sky-600 underline">info@adld.center</a>.</p>
        </div>
      </div>

      <!-- Contact -->
      <div class="bg-[#0a2342] text-white rounded-2xl p-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <p class="font-bold">Questions about donating?</p>
          <p class="text-blue-200 text-sm mt-1">We are happy to help. Reach out to our team directly.</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 flex-shrink-0">
          <a href="mailto:info@adld.center" class="bg-white text-[#0a2342] px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-sky-50 transition-colors text-center">Email Us</a>
          <a href="tel:5072932427" class="bg-white/10 text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-white/20 transition-colors text-center">507-293-2427</a>
        </div>
      </div>

    </div>
  </div>

</Layout>
