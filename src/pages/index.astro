        </div>
      </div>
      <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-50 border border-slate-100">
        <div class="w-8 h-8 rounded-lg bg-[#0a2342] text-white flex items-center justify-center flex-shrink-0 mt-0.5">
