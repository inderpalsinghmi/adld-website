# ADLD Center — Notion CMS Environment Variables
#
# Copy this file to .env for local development.
# In GitHub Actions, add these as repository Secrets (Settings → Secrets → Actions).
#
# NEVER commit .env to version control.

# Your Notion integration token.
# Create one at: https://www.notion.so/my-integrations
# Make sure the integration has "Read content" permission.
# Share your root page (and all sub-pages) with the integration.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The page ID of your root "ADLD Website" Notion page.
# Find it in the page URL: notion.so/Your-Page-Title-{PAGE_ID}
# The page ID is the 32-character hex string at the end (hyphens optional).
#
# Expected structure under this root page:
#   index                 → index.html
#     patient-p1          → <!-- NC:patient-p1 -->
#     patient-p2          → <!-- NC:patient-p2 -->
#     patient-p3          → <!-- NC:patient-p3 -->
#     patient-p4          → <!-- NC:patient-p4 -->
#     patient-p5          → <!-- NC:patient-p5 -->
#     researchers-body    → <!-- NC:researchers-body -->
#     pharma-body         → <!-- NC:pharma-body -->
#   about                 → about.html
#     about-body          → <!-- NC:about-body -->
#   team                  → team.html
#     team-leadership     → <!-- NC:team-leadership -->
#     team-partners       → <!-- NC:team-partners -->
#   resources             → resources.html
#     resources-body      → <!-- NC:resources-body -->
#   research-roadmap      → research-roadmap.html
#     roadmap-t1          → <!-- NC:roadmap-t1 -->
#     roadmap-t2          → <!-- NC:roadmap-t2 -->
#     roadmap-t3          → <!-- NC:roadmap-t3 -->
#     roadmap-t4          → <!-- NC:roadmap-t4 -->
#   natural-history-study → natural-history-study.html
#     nhs-what-is         → <!-- NC:nhs-what-is -->
#     nhs-participate     → <!-- NC:nhs-participate -->
#     nhs-faq             → <!-- NC:nhs-faq -->
NOTION_ROOT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
